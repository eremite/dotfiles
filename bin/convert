#!/usr/bin/env sh

if [ $# -eq 0 ]; then
  >&2 echo "convert in.mp4 # Creates a playable in.mp4, backing up to in_old.mp4"
  exit 1
fi

for infile in "$@"; do
  outfile="$infile"
  backupfile="${infile%%.*}_old.mp4"
  mv "$infile" "$backupfile"
  ffmpeg -i "$backupfile" -c:v libx264 -preset superfast -crf 20 -vf "fps=30,format=yuv420p" -c:a aac -ar 44100 -movflags +faststart "$outfile"
done
